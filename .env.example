# =========================================================================
# Investment research platform — backend environment (Round 0)
# =========================================================================
# Copy to `.env` and tune per deployment. Every value here has a safe
# default inside the code; override only when you need to deviate.

# ---- data source ---------------------------------------------------------
# demo       — deterministic synthetic snapshot (truth_grade=E).
# hybrid     — Eastmoney + Tencent + Yahoo (research_only, grade=C). Default.
# yfinance   — Yahoo only.
DATA_SOURCE=hybrid

# ---- vendor timeouts (seconds) — Round 0 tightening -----------------------
# Keep each vendor under 2s so the serial Eastmoney → Tencent → Yahoo
# fallback chain fits inside the request deadline below.
EASTMONEY_TIMEOUT_SECONDS=1.5
TENCENT_TIMEOUT_SECONDS=1.5
YF_TIMEOUT_SECONDS=2.0

# ---- research-tier rate limits (seconds between calls per vendor) --------
EASTMONEY_RATE_LIMIT_SECONDS=0.25
TENCENT_RATE_LIMIT_SECONDS=0.35
SINA_RATE_LIMIT_SECONDS=0.5
YAHOO_RATE_LIMIT_SECONDS=1.2
RESEARCH_RATE_LIMIT_SECONDS=3.0

# ---- vendor circuit breaker ----------------------------------------------
# Opens after N consecutive failures, auto-half-open after cooldown.
VENDOR_BREAKER_THRESHOLD=3
VENDOR_BREAKER_COOLDOWN_SECONDS=20

# ---- snapshot cache ------------------------------------------------------
# Jitter applied to TTL so many keys don't invalidate at the same instant.
SNAPSHOT_CACHE_JITTER_FRAC=0.10
# Eastmoney per-process memo (separate from the snapshot cache).
EASTMONEY_CACHE_TTL=60

# ---- sentiment read deadline + cache -------------------------------------
# Round 0 target: < 4s end-to-end on a warm cache.
SENTIMENT_READ_DEADLINE_SECONDS=4.0
SENTIMENT_CACHE_TTL=60

# ---- market snapshot refresh (scheduler) ---------------------------------
MARKET_REFRESH_TIMEOUT_SECONDS=6
MARKET_PRIORITY_VIEW=cn_a
MARKET_PRIORITY_WINDOW=20D

# ---- debug / observability -----------------------------------------------
# When DEBUG=true the /api/v1/debug/* routes are mounted:
#   GET /api/v1/debug/health
#   GET /api/v1/debug/data-probe?symbols=000300.SS,HSI&market_view=cn_a
#   GET /api/v1/debug/vendor-health
#   GET /api/v1/debug/cache-stats
#   GET /api/v1/debug/universes
DEBUG=false
LOG_LEVEL=INFO

# ---- CORS ----------------------------------------------------------------
FRONTEND_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
